# Local backend overrides.
# If your local PostgreSQL uses the team default pandacode/postgreskh,
# these DB values can be omitted.
SERVER_PORT=8001
LOCAL_DB_URL=jdbc:postgresql://localhost:5432/code_hit
LOCAL_DB_USERNAME=pandacode
LOCAL_DB_PASSWORD=postgreskh
LOCAL_DDL_AUTO=update
LOCAL_SEED_ENABLED=true
LOCAL_PUBLIC_BASE_URL=http://localhost:8001

# Frontend public keys.
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://localhost:8001
VITE_SERVER_BASE_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001/ws-connect
VITE_S3_ASSET_BASE_URL=https://finalproject-s3-bucket-243050855199-ap-northeast-2-an.s3.ap-northeast-2.amazonaws.com
VITE_NAVER_CLIENT_ID=
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_JS_KEY=
VITE_GOOGLE_CLIENT_ID=
# Optional. The frontend falls back to the previous Toss test client key when omitted.
VITE_TOSS_CLIENT_KEY=

# Backend payment secret. Must match VITE_TOSS_CLIENT_KEY mode: test_* with test_*, live_* with live_*.
TOSS_SECRET_KEY=

# Mail. Required for email verification/password reset flows.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_HEALTH_ENABLED=false

# Local OAuth callback URLs.
VITE_NAVER_REDIRECT_URI=http://localhost:5173/oauth/callback/naver
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth/callback/kakao
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google

# Backend OAuth secrets.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:5173/oauth/callback/naver
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/callback/kakao
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google

# JWT and S3.
JWT_SECRET=local-dev-jwt-secret-must-be-over-32-characters
JWT_EXPIRATION=360000000
AWS_S3_BUCKET=finalproject-s3-bucket-243050855199-ap-northeast-2-an
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BASE_URL=https://finalproject-s3-bucket-243050855199-ap-northeast-2-an.s3.ap-northeast-2.amazonaws.com

# Cloud defaults used by deployment workflows.
APP_PUBLIC_BASE_URL=https://api.sandykey.shop
APP_CORS_ALLOWED_ORIGINS=https://sandykey.shop
