# Local backend overrides.
# If your local PostgreSQL uses the team default pandacode/postgreskh,
# these DB values can be omitted.
LOCAL_DB_URL=jdbc:postgresql://localhost:5432/code_hit
LOCAL_DB_USERNAME=pandacode
LOCAL_DB_PASSWORD=postgreskh

# Frontend public keys.
VITE_NAVER_CLIENT_ID=
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_JS_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_TOSS_CLIENT_KEY=

# Backend payment secret. Must match VITE_TOSS_CLIENT_KEY mode: test_* with test_*, live_* with live_*.
TOSS_SECRET_KEY=

# Local OAuth callback URLs.
VITE_NAVER_REDIRECT_URI=http://localhost:5173/oauth/callback/naver
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth/callback/kakao
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google

# Backend OAuth secrets.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:5173/oauth/callback/naver
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/callback/kakao
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google
